# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-at-least-16-chars-long
JWT_EXPIRES_IN=7d

# Google Drive Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive Folder IDs
DRIVE_FOLDER_TEMPLATES_PHOTOS=folder_id
DRIVE_FOLDER_TEMPLATES_VIDEOS=folder_id
DRIVE_FOLDER_TEMPLATES_AUDIOS=folder_id
DRIVE_FOLDER_CLIENT_PHOTOS=folder_id
DRIVE_FOLDER_CLIENT_VIDEOS=folder_id

# Google OAuth (for user login via Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://toyga.kz/api/auth/google-callback

# WhatsApp Gateway (self-hosted, see services/whatsapp-gateway/)
WHATSAPP_GATEWAY_URL=http://localhost:3001
WHATSAPP_GATEWAY_TOKEN=your-gateway-bearer-token

# App
NODE_ENV=development
APP_URL=http://localhost:5173
