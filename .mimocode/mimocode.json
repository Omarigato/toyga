{
    "mcp": {
        "shadcn": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "shadcn@latest",
                "mcp"
            ],
            "enabled": true
        },
        "magicuidesign": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@magicuidesign/mcp@latest",
                "mcp"
            ],
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        }
    },
    "$schema": "https://mimo.xiaomi.com/mimocode/config.json"
}