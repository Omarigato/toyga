# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/toyga?schema=public

# JWT
JWT_SECRET=your-secret-key-at-least-16-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (user login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# Google Drive (file storage)
GOOGLE_DRIVE_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_root_folder_id

# WhatsApp Gateway (self-hosted Baileys)
WHATSAPP_GATEWAY_URL=http://localhost:3001
WHATSAPP_GATEWAY_TOKEN=your-gateway-bearer-token

# App
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# Swagger
SWAGGER_ENABLED=true
